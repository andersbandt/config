# Emacs cache/state directories
emacs/.emacs.d/.cache/
emacs/.emacs.d/.saves/
emacs/.emacs.d/elpa/

# Emacs session/state files (machine-specific)
emacs/.emacs.d/session*
emacs/.emacs.d/ido.last
emacs/.emacs.d/elgrep-data.el

# Machine-local overrides (per-machine flags, not shared across machines)
emacs/.emacs.d/local.el

# Compiled Emacs files
*.elc

# Emacs backup/lock files
~*
*.bak
.#*

# Claude Code local settings (machine-specific)
.claude/settings.local.json
